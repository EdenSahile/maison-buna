{
  "name": "maison-buna-devis",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "dev:client": "cd client && npm run dev",
    "dev:all": "concurrently -n API,React -c cyan,magenta \"nodemon server.js\" \"cd client && npm run dev\"",
    "start": "NODE_ENV=production node server.js",
    "build": "cd client && npm run build",
    "pdf:test": "node scripts/test-pdf.js",
    "mail:test": "node scripts/test-mail.js",
    "test": "cd client && npm test",
    "postinstall": "npx puppeteer browsers install chrome"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.0",
    "helmet": "^8.2.0",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.0.0"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*",
      "scripts/test-output.pdf",
      "handoffs/*"
    ]
  }
}
